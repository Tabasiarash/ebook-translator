# Telegram
TELEGRAM_BOT_TOKEN=             # Required: Bot token from @BotFather
TELEGRAM_API_BASE_URL=https://api.telegram.org  # Custom Bot API server if using one
TELEGRAM_API_FILE_BASE_URL=https://api.telegram.org

# Redis
REDIS_URL=redis://127.0.0.1:6379/0  # May include password: redis://:password@host:port/0

# Paths
BASE_DIR=/var/www/ebook-translator  # Root directory for jobs, DB, providers
DB_PATH=                             # Default: <BASE_DIR>/db.sqlite3
PROVIDERS_PATH=                      # Default: <BASE_DIR>/providers.yaml
LOG_DIR=/var/log/ebook-translator
FONT_DIR=                            # Default: <BASE_DIR>/fonts
DOWNLOAD_TMP_DIR=/tmp/tgbot_downloads

# Provider keys (see providers.yaml for structure)
# Each provider section lists API keys under the provider name

# Downloads
COOKIES_FILE=                        # Path to cookies.txt for YouTube/restricted content
MAX_UPLOAD_MB=1900                   # Telegram upload limit (default 1900 MB)
PER_USER_COOLDOWN_SECONDS=60         # Cooldown between downloads per user
MAX_CONCURRENT_DOWNLOADS=3           # Max simultaneous downloads

# Bot
BOT_POLL_INTERVAL=5                  # Telegram poll interval in seconds

# Fetch (/fetch command)
FETCH_TIMEOUT_SECONDS=45             # HTTP request timeout
FETCH_MAX_MB=100                     # Max response size to relay
FETCH_PER_USER_COOLDOWN_SECONDS=30   # Cooldown between fetches per user
